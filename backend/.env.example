# ── Replicate API (get token from https://replicate.com/account/api-tokens) ──
# Set this to enable always-on AI generation without Colab.
REPLICATE_API_TOKEN=r8_your_token_here

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Add your Vercel URL here after deploying.
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# ── Flask ────────────────────────────────────────────────────────────────────
# Set to "true" only in local development.
FLASK_DEBUG=false

# ── Optional: override Replicate model versions ──────────────────────────────
# REPLICATE_IMG2IMG_MODEL=stability-ai/stable-diffusion-img2img:15a3689ee13b0d2616e98820eca31d4af4a36b65a5a4aaf3ded1c69a29fb5e8
# REPLICATE_INPAINT_MODEL=stability-ai/stable-diffusion-inpainting:95b7223104132402a9ae91cc677285bc5eb997834bd2349fa486f53910fd68b3

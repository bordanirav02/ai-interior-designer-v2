# ── Backend API URL ──────────────────────────────────────────────────────────
# Point this to your deployed Render backend URL.
# For local dev, leave as http://localhost:5000 (or omit — that's the default).
REACT_APP_API_URL=https://your-backend.onrender.com

# ── Firebase (already set in firebase.js, but you can move them here) ────────
# REACT_APP_FIREBASE_API_KEY=...
# REACT_APP_FIREBASE_AUTH_DOMAIN=...
# REACT_APP_FIREBASE_PROJECT_ID=...
